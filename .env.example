# ============================================================================
# Action1 API credentials — create these under Configuration > Users & API Credentials
# ============================================================================
ACTION1_CLIENT_ID=your_client_id_here
ACTION1_CLIENT_SECRET=your_client_secret_here

# Region: na (default) | eu | au
ACTION1_REGION=na

# Default organization ID (optional — can be passed per-tool call)
ACTION1_ORG_ID=

# Safety guard. When false (default), deploy/run_script tools refuse to run
# unless group_ids or endpoint_ids are explicitly provided, preventing an
# accidental fleet-wide change. Set to true only if you really want to allow
# targeting ALL endpoints by default.
ACTION1_ALLOW_ALL_ENDPOINTS=false

# When true, only read-only inspection tools are exposed (no deploy / run /
# delete). Useful for a safe initial rollout.
ACTION1_READONLY=false

# ============================================================================
# Transport
# ============================================================================
# stdio (default, for local desktop clients) | http (Streamable HTTP, for a
# remote container attached to Claude)
MCP_TRANSPORT=stdio

# Port for the HTTP transport
PORT=3000

# Public, externally reachable base URL of this server. Used to build the OAuth
# protected-resource metadata advertised to clients. Required for http transport.
MCP_PUBLIC_URL=https://mcp-action1.example.com

# ============================================================================
# Microsoft Entra ID (Azure AD) authentication — required for http transport
# ============================================================================
# Directory (tenant) ID of your Entra tenant
ENTRA_TENANT_ID=

# Application (client) ID of the Entra app registration that represents this API
ENTRA_CLIENT_ID=

# Object ID of the security group whose members are allowed to use the server
ENTRA_REQUIRED_GROUP_ID=

# Optional: comma-separated list of accepted token audiences.
# Defaults to "<ENTRA_CLIENT_ID>,api://<ENTRA_CLIENT_ID>".
ENTRA_AUDIENCE=

# Optional: require this app role instead of / in addition to group membership.
# Recommended when users may belong to >200 groups (groups overage).
ENTRA_REQUIRED_APP_ROLE=
